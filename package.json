{
  "name": "@hlos/paid",
  "version": "0.2.0",
  "description": "Turn any MCP tool or API route into a paid capability in one line of code.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./context": {
      "import": {
        "types": "./dist/context.d.ts",
        "default": "./dist/context.js"
      },
      "require": {
        "types": "./dist/context.d.cts",
        "default": "./dist/context.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "INTEGRATION.md",
    "DEPENDENCIES.md",
    "PROTOCOL.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/context.ts --format esm,cjs --dts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:pkg": "publint"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.17.0",
    "publint": "^0.3.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hlos-ai/paid.git"
  },
  "homepage": "https://github.com/hlos-ai/paid",
  "bugs": {
    "url": "https://github.com/hlos-ai/paid/issues"
  }
}
