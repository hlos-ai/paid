{
  "name": "@hlos/paid",
  "version": "0.1.0",
  "description": "Turn any MCP tool or API route into a paid capability in one line of code.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "DEPENDENCIES.md",
    "PROTOCOL.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
